# ═══════════════════════════════════════════════════════════════════════════
# SPJ App — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ─── Mode Dokumen Referensi ───────────────────────────────────────────
# local    : file PDF dari spj-frontend/public/docs/ (development)
# drive    : file PDF dari Google Drive (production / Vercel)
# electron : file PDF dari resources app (Electron desktop)
#
# Cara setting di Vercel Dashboard:
#   Settings → Environment Variables → VITE_DOCS_MODE = drive
VITE_DOCS_MODE=local

# ─── Google Drive File IDs ─────────────────────────────────────────────
# Mode 'drive': isi File ID dari Google Drive untuk setiap dokumen.
# Cara dapat File ID:
#   1. Upload PDF ke drive.google.com
#   2. Set sharing: "Anyone with the link"
#   3. Copy link → https://drive.google.com/file/d/{FILE_ID}/view
#   4. Isi FILE_ID ke variable di bawah ini
#
# Contoh: VITE_DOCS_PERMENDAGRI=1Wb2NfKTQr_dLoFJH0GfM0cx
VITE_DOCS_PERMENDAGRI=
VITE_DOCS_JUKNIS_BOSP=
VITE_DOCS_PERBUP=
VITE_DOCS_PERBUP_REVISI=
VITE_DOCS_PERMENDIKBUDRISTEK_18=

# ─── AI Provider ───────────────────────────────────────────────────────
# Dapatkan API Key gratis dari:
# Google Gemini: https://aistudio.google.com/apikey
# Groq: https://console.groq.com/keys
#
# Cukup isi SALAH SATU saja:
# - VITE_GEMINI_API_KEY → GRATIS (rate limited, cukup untuk MVP)
# - VITE_GROQ_API_KEY  → BERBAYAR ($0.05/1M token, unlimited)

# REKOMENDASI: Gunakan Gemini (GRATIS)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Alternatif: Groq (BERBAYAR, sangat murah)
# VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Model yang digunakan (default: gemini-2.0-flash)
# VITE_AI_MODEL=gemini-2.0-flash
# VITE_AI_MODEL=llama-3.1-8b-instant

# ─── CARA MENDAPATKAN API KEY ─────────────────────────────────────
# 1. Buka https://aistudio.google.com/apikey
# 2. Klik "Create API Key"
# 3. Copy key dan paste di atas (ganti YOUR_GEMINI_API_KEY_HERE)
# 4. Selesai! Tidak perlu kartu kredit.
#
# Jika menggunakan Groq:
# 1. Buka https://console.groq.com/keys
# 2. Login dengan akun Google/GitHub
# 3. Klik "Create API Key"
# 4. Isi nama (misal: "SPJ App") → Create
# 5. Copy key dan paste
